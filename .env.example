# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Anthropic Claude API key (required for AI-powered sentiment and thesis generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram bot credentials (optional — used for price alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord bot credentials (optional — used for !analyze / !price / !dcf / !score commands)
# Create a bot at https://discord.com/developers/applications
# Required scope: bot  |  Required intents: Message Content Intent
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=        # optional: restrict to one channel (right-click channel → Copy ID)
DAILY_SUMMARY_TIME=16:30   # HH:MM local time for automatic daily portfolio post (after US close)
EARNINGS_ALERT_TIME=09:00  # HH:MM local time for earnings countdown alerts (7d/2d/1d before)
PORTFOLIO_TICKERS=         # comma-separated fallback if TWS is offline e.g. AAPL,NVDA,TSLA

# Interactive Brokers TWS / IB Gateway connection
TWS_HOST=127.0.0.1
TWS_PORT=7497        # 7497=TWS paper, 7496=TWS live, 4002=Gateway paper, 4001=Gateway live
TWS_CLIENT_ID=10
