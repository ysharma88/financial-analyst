# Copy to .streamlit/secrets.toml for local dev, or paste into
# Streamlit Cloud → App settings → Secrets.
#
# NEVER commit secrets.toml to git.

ANTHROPIC_API_KEY = "sk-ant-..."

# Optional — only needed for Telegram price alerts
TELEGRAM_BOT_TOKEN = ""
TELEGRAM_CHAT_ID   = ""

# Optional — only needed for Discord bot (not functional on cloud)
DISCORD_BOT_TOKEN  = ""
DISCORD_CHANNEL_ID = ""
